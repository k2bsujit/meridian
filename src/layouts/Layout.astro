---
import Header from "../components/nav/Header.astro";
import Footer from "../components/shared/Footer.astro";
import MobileCTABar from "../components/shared/MobileCTABar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "MERIDIAN is a collection of architect-designed residences across Miami's waterfront neighborhoods — quiet-luxury living, considered detail.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- PLACEHOLDER: replace favicon.svg with the real brand mark -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · MERIDIAN</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#14140F" />
    <meta property="og:title" content={`${title} · MERIDIAN`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="pb-[calc(3.5rem+env(safe-area-inset-bottom))] xl:pb-0">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:bg-bone focus:px-4 focus:py-2 focus:text-ink"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MobileCTABar />
    <script src="../scripts/motion.js"></script>
  </body>
</html>
