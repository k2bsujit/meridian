---
---

<section
  class="relative flex h-[100svh] min-h-[640px] w-full items-end overflow-hidden bg-ink"
  data-reveal-group
>
  <!-- PLACEHOLDER: temporary free stock photo (Unsplash License) -- swap for commissioned/final photography -->
  <img
    data-kenburns
    src="/images/hero-exterior.avif"
    alt="Waterfront modern residence at sunset with infinity pool, banyan tree, and the Miami skyline across Biscayne Bay"
    class="absolute inset-0 h-full w-full object-cover will-change-transform"
    fetchpriority="high"
  />
  <div
    class="absolute inset-0"
    style="background: radial-gradient(circle at 70% 30%, rgba(176,139,87,0.15), transparent 55%);"
  >
  </div>
  <div class="absolute inset-0 bg-overlay"></div>

  <div
    class="relative z-10 mx-auto w-full max-w-[1600px] px-6 pb-20 md:px-10 md:pb-28"
  >
    <p data-reveal class="mb-4 text-sm uppercase tracking-[0.2em] text-brass">
      South Florida, Considered
    </p>
    <h1
      data-reveal
      class="max-w-6xl font-display text-[clamp(2.75rem,6.5vw,5.5rem)] leading-[1.1] text-bone"
    >
      Residences built for Miami's unhurried edge.
    </h1>
    <!-- PLACEHOLDER: replace with real hero copy -->
    <p
      data-reveal
      class="mt-6 max-w-[50ch] text-base leading-relaxed text-bone/80 md:text-lg"
    >
      MERIDIAN gathers architect-designed residences across Miami's
      waterfront neighborhoods — where Biscayne Bay light, banyan-lined
      streets, and unglossy craftsmanship meet.
    </p>
  </div>

  <div
    data-reveal
    class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-center text-bone/60"
  >
    <span class="mx-auto block h-10 w-px animate-pulse bg-bone/40"></span>
    <span class="sr-only">Scroll to explore</span>
  </div>
</section>
