---
import { residences } from "../../data/residences.js";
---

<section
  class="mx-auto max-w-[1600px] px-6 py-32 md:px-10 md:py-40"
  data-reveal-group
>
  <div
    class="mb-14 flex flex-col gap-4 md:mb-20 md:flex-row md:items-end md:justify-between"
  >
    <h2
      data-reveal
      class="font-display text-[clamp(2rem,4vw,3.25rem)] leading-[1.05] text-ink"
    >
      Featured Residences
    </h2>
    <a
      data-reveal
      href="/residences"
      class="group inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink"
    >
      View All Residences
      <span
        class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass"
      ></span>
    </a>
  </div>

  <div class="grid gap-x-8 gap-y-16 md:grid-cols-12">
    {
      residences.map((r, i) => (
        <a
          href={`/residences/${r.slug}`}
          data-reveal
          class={`group md:col-span-6 ${i === 1 ? "md:col-start-7 md:mt-24" : ""} ${i === 2 ? "md:col-span-5 md:col-start-2" : ""} ${i === 3 ? "md:col-span-5 md:col-start-8 md:mt-12" : ""}`}
        >
          <div class="overflow-hidden transition-transform duration-500 group-hover:scale-[1.02]" style="aspect-ratio: 4/5;">
            <img
              data-parallax
              src={r.heroImage.src}
              alt={r.heroImage.alt}
              class="h-full w-full object-cover will-change-transform"
              loading="lazy"
            />
          </div>
          <h3 class="mt-5 font-display text-2xl text-ink">{r.name}</h3>
          <p class="mt-1 text-sm uppercase tracking-wide text-stone">
            {r.neighborhood}
          </p>
          <p class="mt-3 max-w-[45ch] text-sm leading-relaxed text-stone">
            {r.blurb}
          </p>
        </a>
      ))
    }
  </div>
</section>
