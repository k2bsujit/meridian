---

<section
  class="relative overflow-hidden bg-ink py-32 text-center text-bone md:py-44"
  data-reveal-group
>
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(circle at 50% 30%, rgba(176,139,87,0.12), transparent 60%);"
  >
  </div>
  <div class="relative z-10 mx-auto max-w-2xl px-6">
    <p data-reveal class="text-sm uppercase tracking-[0.15em] text-brass">
      Begin Here
    </p>
    <h2
      data-reveal
      class="mt-4 font-display text-[clamp(2.25rem,5vw,4rem)] leading-[1.05]"
    >
      Arrange a private tour.
    </h2>
    <p
      data-reveal
      class="mx-auto mt-6 max-w-[45ch] text-base leading-relaxed text-bone/80"
    >
      Spend an hour walking through a residence with us — no obligation,
      just a conversation about what you're looking for.
    </p>
    <a
      data-reveal
      href="/contact#schedule"
      class="mt-10 inline-block rounded-full border border-brass px-8 py-3.5 text-sm uppercase tracking-wide text-bone transition-colors duration-300 hover:bg-brass hover:text-ink"
    >
      Schedule Appointment
    </a>
  </div>
</section>
