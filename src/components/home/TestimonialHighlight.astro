---
// PLACEHOLDER: testimonial quotes are illustrative
const quotes = [
  {
    quote:
      "Every detail felt considered before we even asked the question. It's the first Miami home that's ever felt quiet.",
    name: "R. & S. Whitfield",
    detail: "Owners, The Grove House",
  },
  {
    quote:
      "MERIDIAN didn't sell us a listing. They walked us through a way of living on the bay and let the house speak for itself.",
    name: "J. Okafor",
    detail: "Owner, Sunset Harbour Row",
  },
];
---

<!-- PLACEHOLDER: testimonial quotes are illustrative -->
<section class="border-y border-stone/15 bg-bone py-32 md:py-40" data-reveal-group>
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <div class="grid gap-16 md:grid-cols-2 md:gap-12">
      {
        quotes.map((q) => (
          <blockquote data-reveal>
            <p class="font-display text-[clamp(1.5rem,2.4vw,2rem)] leading-[1.25] text-ink">
              "{q.quote}"
            </p>
            <footer class="mt-6 text-sm uppercase tracking-wide text-stone">
              {q.name} — {q.detail}
            </footer>
          </blockquote>
        ))
      }
    </div>
    <a data-reveal href="/testimonials" class="group mt-16 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink">
      Read More Testimonials
      <span class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass"></span>
    </a>
  </div>
</section>
