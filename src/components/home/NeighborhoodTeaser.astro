---

<section class="mx-auto max-w-[1600px] px-6 py-32 md:px-10 md:py-40" data-reveal-group>
  <div class="grid gap-10 md:grid-cols-12 md:gap-8">
    <div data-reveal class="md:col-span-5 overflow-hidden" style="aspect-ratio: 4/5;">
      <!-- PLACEHOLDER: temporary free stock photo (Unsplash License) -- swap for commissioned/final photography -->
      <img
        data-parallax
        src="/images/neighborhood-street.avif"
        alt="Sunny coastal Miami streetscape at golden hour"
        class="h-full w-full object-cover will-change-transform"
        loading="lazy"
      />
    </div>
    <div class="md:col-span-6 md:col-start-7 md:self-center">
      <p data-reveal class="text-sm uppercase tracking-[0.15em] text-ink/70">
        Neighborhood
      </p>
      <h2
        data-reveal
        class="mt-4 font-display text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] text-ink"
      >
        Set along Biscayne Bay.
      </h2>
      <!-- PLACEHOLDER: replace with real neighborhood copy -->
      <p data-reveal class="mt-6 max-w-[45ch] text-base leading-relaxed text-stone">
        Ten minutes from the Design District, walking distance to
        Coconut Grove's oldest banyan canopy, and close enough to the
        bay to hear it at night.
      </p>
      <a
        data-reveal
        href="/neighborhood"
        class="group mt-8 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink"
      >
        Discover the Neighborhood
        <span class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass"></span>
      </a>
    </div>
  </div>
</section>
