<section class="relative overflow-hidden bg-ink py-32 text-bone md:py-40" data-reveal-group>
  <div class="mx-auto grid max-w-[1600px] gap-10 px-6 md:grid-cols-12 md:gap-8 md:px-10">
    <div class="md:col-span-5">
      <p data-reveal class="text-sm uppercase tracking-[0.15em] text-brass">
        The Experience
      </p>
      <h2
        data-reveal
        class="mt-4 font-display text-[clamp(2rem,3.5vw,3rem)] leading-[1.1]"
      >
        Amenities considered<br /> like architecture.
      </h2>
      <!-- PLACEHOLDER: replace with real amenities copy -->
      <p data-reveal class="mt-6 max-w-[45ch] text-base leading-relaxed text-bone/80">
        A rooftop pool over Biscayne Bay, a private dock for the boat you
        haven't bought yet, a screening room shaded from the afternoon
        sun — each space designed with the same restraint as the
        residences themselves.
      </p>
      <a
        data-reveal
        href="/experience"
        class="group mt-8 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-bone"
      >
        Explore The Experience
        <span class="h-px w-6 bg-bone transition-all duration-300 group-hover:w-10"></span>
      </a>
    </div>
    <div data-reveal class="md:col-span-6 md:col-start-7 overflow-hidden" style="aspect-ratio: 16/10;">
      <!-- PLACEHOLDER: temporary free stock photo (Unsplash License) -- swap for commissioned/final photography -->
      <img
        data-parallax
        src="/images/experience-lounge.avif"
        alt="Resident lounge interior with warm minimal materials"
        class="h-full w-full object-cover will-change-transform"
        loading="lazy"
      />
    </div>
  </div>
</section>
