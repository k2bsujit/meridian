---
import Logo from "./Logo.astro";

const links = [
  { label: "Residences", href: "/residences" },
  { label: "Gallery", href: "/gallery" },
  { label: "The Experience", href: "/experience" },
  { label: "Neighborhood", href: "/neighborhood" },
  { label: "Testimonials", href: "/testimonials" },
  { label: "About", href: "/about" },
  { label: "Journal", href: "/journal" },
  { label: "Contact", href: "/contact" },
  { label: "FAQ", href: "/faq" },
];

const socials = ["Instagram", "LinkedIn", "Facebook"];

const year = new Date().getFullYear();
---

<footer class="border-t border-stone/15 bg-ink text-bone">
  <div class="mx-auto max-w-[1600px] px-6 py-16 md:px-10 md:py-24">
    <div class="grid gap-12 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-4">
        <Logo variant="light" />
        <!-- PLACEHOLDER: replace with real brand descriptor -->
        <p class="mt-6 max-w-[32ch] text-sm leading-relaxed text-stone">
          A quiet standard of residential architecture, considered detail,
          and unhurried living.
        </p>
      </div>

      <nav aria-label="Footer" class="md:col-span-4">
        <ul class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-stone transition-colors duration-300 hover:text-brass"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="md:col-span-4">
        <h2 class="text-sm uppercase tracking-[0.15em] text-stone">
          Stay Informed
        </h2>
        <!-- Newsletter signup stub — no third-party embed wired yet, per CLAUDE.md §3 -->
        <form
          name="newsletter"
          method="POST"
          data-netlify="true"
          class="mt-4 flex border-b border-stone/40 focus-within:border-brass"
        >
          <input type="hidden" name="form-name" value="newsletter" />
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder="Email address"
            class="w-full bg-transparent py-2 text-sm text-bone placeholder:text-stone/70 focus:outline-none"
          />
          <button
            type="submit"
            class="shrink-0 text-sm uppercase tracking-wide text-brass"
          >
            Submit
          </button>
        </form>

        <div class="mt-10">
          <h2 class="text-sm uppercase tracking-[0.15em] text-stone">
            Sales Office
          </h2>
          <!-- TODO: real contact info -->
          <address class="mt-3 text-sm leading-relaxed text-stone not-italic">
            2 South Bayshore Drive, Suite 200<br />
            Coconut Grove, Miami, FL 33133<br />
            <a href="tel:+13055550100" class="hover:text-brass"
              >+1 (305) 555-0100</a
            >
          </address>
        </div>
      </div>
    </div>

    <div
      class="mt-16 flex flex-col gap-6 border-t border-stone/15 pt-8 md:flex-row md:items-center md:justify-between"
    >
      <ul class="flex gap-5">
        {
          socials.map((label) => (
            <li>
              <a
                href="#"
                aria-label={label}
                class="text-stone transition-colors duration-300 hover:text-brass"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="9" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>

      <ul
        class="flex flex-wrap gap-x-6 gap-y-2 text-xs uppercase tracking-wide text-stone"
      >
        <li><a href="/privacy" class="hover:text-brass">Privacy Policy</a></li>
        <li>
          <a href="/accessibility" class="hover:text-brass"
            >Accessibility Statement</a
          >
        </li>
        <li><a href="/terms" class="hover:text-brass">Terms</a></li>
      </ul>

      <p class="text-xs text-stone">© {year} MERIDIAN. All rights reserved.</p>
    </div>
  </div>
</footer>
