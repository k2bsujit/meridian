---
import Layout from "../../layouts/Layout.astro";
import { residences } from "../../data/residences.js";
---

<Layout
  title="Residences"
  description="A collection of architect-designed residences across Miami's waterfront neighborhoods -- Coconut Grove, Bay Harbor Islands, Sunset Harbour, and Belle Meade."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">
      Residences
    </p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      Four neighborhoods, one standard.
    </h1>
    <p data-reveal class="mt-6 max-w-[60ch] text-base leading-relaxed text-stone md:text-lg">
      Each MERIDIAN residence is designed independently, in dialogue with
      its own site and light, rather than repeated from a shared template.
      What carries across the collection is restraint -- in material,
      in massing, in the way a house meets its street.
    </p>
  </section>

  <section class="mx-auto max-w-[1600px] px-6 pb-32 md:px-10 md:pb-40" data-reveal-group>
    <div class="space-y-24 md:space-y-32">
      {
        residences.map((r, i) => (
          <a
            href={`/residences/${r.slug}`}
            data-reveal
            class="group grid gap-8 md:grid-cols-12 md:gap-8 md:items-center"
          >
            <div
              class={`overflow-hidden md:col-span-7 ${i % 2 === 1 ? "md:col-start-6" : ""}`}
              style="aspect-ratio: 4/5;"
            >
              <img
                data-parallax
                src={r.heroImage.src}
                alt={r.heroImage.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02] will-change-transform"
                loading="lazy"
              />
            </div>
            <div class={`md:col-span-4 ${i % 2 === 1 ? "md:col-start-1 md:row-start-1" : "md:col-start-9"}`}>
              <p class="text-sm uppercase tracking-wide text-stone">
                {r.neighborhood}
              </p>
              <h2 class="mt-3 font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-[1.1] text-ink">
                {r.name}
              </h2>
              <p class="mt-4 max-w-[42ch] text-base leading-relaxed text-stone">
                {r.blurb}
              </p>
              <p class="mt-6 text-sm uppercase tracking-wide text-ink/70">
                {r.specs.beds} Bed &middot; {r.specs.baths} Bath &middot; {r.specs.sqft} Sq Ft
              </p>
              <span class="mt-8 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink">
                View Residence
                <span class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="border-t border-stone/15 bg-ink py-24 text-bone md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
      <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.1]">
        Not seeing what you're looking for?
      </h2>
      <p data-reveal class="mx-auto mt-4 max-w-[50ch] text-base leading-relaxed text-bone/80">
        New residences are released quietly, ahead of public listing.
        Schedule a call and we'll share what's coming next.
      </p>
      <a
        data-reveal
        href="/contact#schedule"
        class="mt-8 inline-block rounded-full border border-brass px-7 py-3 text-sm tracking-wide text-bone transition-colors duration-300 hover:bg-brass hover:text-ink"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</Layout>
