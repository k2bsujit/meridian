---
import Layout from "../layouts/Layout.astro";
import { residences } from "../data/residences.js";
---

<Layout
  title="Contact"
  description="Schedule a private tour, ask a question, or reach the MERIDIAN sales office directly."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">Contact</p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      Let's talk about your next home.
    </h1>
  </section>

  <section id="schedule" class="mx-auto max-w-[1600px] scroll-mt-28 px-6 pb-32 md:px-10 md:pb-40" data-reveal-group>
    <div class="grid gap-12 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-5">
        <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] leading-[1.1] text-ink">
          Schedule Appointment
        </h2>
        <p data-reveal class="mt-6 max-w-[42ch] text-base leading-relaxed text-stone">
          Tell us a little about what you're looking for and we'll follow
          up within one business day to arrange a private tour or call.
        </p>

        <!-- PLACEHOLDER: replace with real office contact info -->
        <div data-reveal class="mt-12">
          <h3 class="text-sm uppercase tracking-[0.15em] text-stone">Direct Contact</h3>
          <!-- TODO: real contact info -->
          <p class="mt-3 text-sm leading-relaxed text-ink">
            <a href="tel:+13055550100" class="transition-colors duration-300 hover:text-brass"
              >+1 (305) 555-0100</a
            ><br />
            <a href="mailto:hello@meridian-example.com" class="transition-colors duration-300 hover:text-brass"
              >hello@meridian-example.com</a
            >
          </p>
          <a href="#visit" class="group mt-4 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-stone transition-colors duration-300 hover:text-ink">
            Visit the sales office
            <span class="h-px w-4 bg-stone transition-all duration-300 group-hover:w-8 group-hover:bg-brass" />
          </a>
        </div>
      </div>

      <div data-reveal class="md:col-span-6 md:col-start-7">
        <form
          name="schedule-appointment"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="schedule-appointment" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="name" class="text-sm uppercase tracking-wide text-stone">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                class="mt-2 w-full border-b border-stone/40 bg-transparent py-2 text-ink focus:border-brass focus:outline-none"
              />
            </div>
            <div>
              <label for="email" class="text-sm uppercase tracking-wide text-stone">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="mt-2 w-full border-b border-stone/40 bg-transparent py-2 text-ink focus:border-brass focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="text-sm uppercase tracking-wide text-stone">Phone</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              class="mt-2 w-full border-b border-stone/40 bg-transparent py-2 text-ink focus:border-brass focus:outline-none"
            />
          </div>

          <div>
            <label for="residence" class="text-sm uppercase tracking-wide text-stone">
              Residence of Interest
            </label>
            <div class="relative mt-2">
              <select
                id="residence"
                name="residence"
                class="w-full appearance-none border-b border-stone/40 bg-transparent py-2 pr-8 text-ink focus:border-brass focus:outline-none"
              >
                <option value="">No preference</option>
                {
                  residences.map((r) => (
                    <option value={r.slug}>{r.name}</option>
                  ))
                }
              </select>
              <svg
                width="12"
                height="12"
                viewBox="0 0 12 12"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
                class="pointer-events-none absolute right-1 top-1/2 -translate-y-1/2 text-stone"
              >
                <path d="M2.5 4.5L6 8L9.5 4.5" />
              </svg>
            </div>
          </div>

          <div>
            <label for="message" class="text-sm uppercase tracking-wide text-stone">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="mt-2 w-full border-b border-stone/40 bg-transparent py-2 text-ink focus:border-brass focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="rounded-full border border-ink px-7 py-3 text-sm tracking-wide text-ink transition-colors duration-300 hover:bg-ink hover:text-bone"
          >
            Submit Request
          </button>
        </form>
      </div>
    </div>
  </section>

  <section id="visit" class="border-t border-stone/15 mx-auto max-w-[1600px] scroll-mt-28 px-6 py-24 md:px-10 md:py-32" data-reveal-group>
    <div class="grid gap-12 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-4">
        <p data-reveal class="text-sm uppercase tracking-[0.15em] text-brass">Visit</p>
        <h2 data-reveal class="mt-4 font-display text-[clamp(1.75rem,3.5vw,2.5rem)] leading-[1.1] text-ink">
          See the sales office in person.
        </h2>
        <p data-reveal class="mt-6 max-w-[42ch] text-base leading-relaxed text-stone">
          Tours are arranged by private appointment, but the sales office
          welcomes walk-ins during open hours to view material samples and
          the full collection.
        </p>

        <!-- PLACEHOLDER: replace with real office contact info -->
        <div data-reveal class="mt-10 space-y-6 text-sm">
          <div>
            <p class="text-xs uppercase tracking-[0.15em] text-stone">Address</p>
            <!-- TODO: real contact info -->
            <address class="mt-2 leading-relaxed text-ink not-italic">
              2 South Bayshore Drive, Suite 200<br />
              Coconut Grove, Miami, FL 33133
            </address>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.15em] text-stone">Hours</p>
            <!-- PLACEHOLDER: replace with real office hours -->
            <p class="mt-2 leading-relaxed text-ink">
              Monday &ndash; Saturday, 10am &ndash; 6pm<br />
              Sunday, by appointment
            </p>
          </div>
        </div>

        <a
          data-reveal
          href="https://www.google.com/maps?q=2+South+Bayshore+Drive,+Coconut+Grove,+Miami,+FL+33133"
          target="_blank"
          rel="noopener noreferrer"
          class="group mt-8 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink"
        >
          Get Directions
          <span class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass" />
        </a>
      </div>

      <div data-reveal class="md:col-span-7 md:col-start-6">
        <div class="relative overflow-hidden border border-stone/20" style="aspect-ratio: 4/3;">
          <iframe
            src="https://www.google.com/maps?q=2+South+Bayshore+Drive,+Coconut+Grove,+Miami,+FL+33133&output=embed"
            title="Map showing the MERIDIAN sales office location in Coconut Grove, Miami, FL"
            class="h-full w-full grayscale-[55%] sepia-[12%] contrast-[1.05] brightness-[0.97]"
            style="border:0;"
            loading="lazy"
            allowfullscreen
          ></iframe>
          <div class="pointer-events-none absolute inset-0 bg-ink/10"></div>
          <div class="absolute bottom-4 left-4 border border-brass/40 bg-bone/95 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.15em] text-brass">Sales Office</p>
            <p class="mt-1 text-sm text-ink">Coconut Grove, Miami</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
