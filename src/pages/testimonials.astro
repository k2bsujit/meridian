---
import Layout from "../layouts/Layout.astro";
import { featured, groups } from "../data/testimonials.js";
---

<Layout
  title="Testimonials"
  description="What MERIDIAN residents say about the properties, the process, and the neighborhoods they chose."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">Testimonials</p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      In residents' own words.
    </h1>
    <p data-reveal class="mt-6 max-w-[60ch] text-base leading-relaxed text-stone md:text-lg">
      We ask every resident the same open question a few months after
      closing: what actually mattered? These are their answers, organized
      by residence rather than trimmed into a carousel of star ratings.
    </p>
  </section>

  <!-- Featured pull-quote -->
  <section class="relative overflow-hidden border-y border-stone/15 bg-ink py-28 text-bone md:py-40" data-reveal-group>
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -top-10 left-1/2 -translate-x-1/2 select-none font-display text-[16rem] leading-none text-brass/10 md:text-[22rem]"
    >
      &rdquo;
    </span>
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center md:px-10">
      <p
        data-reveal
        class="font-display text-[clamp(1.75rem,4.2vw,3.25rem)] leading-[1.2] text-bone"
      >
        &ldquo;{featured.quote}&rdquo;
      </p>
      <footer data-reveal class="mt-8 text-sm uppercase tracking-[0.15em] text-brass">
        {featured.name} &mdash; {featured.detail}
      </footer>
    </div>
  </section>

  <!-- Grouped by residence -->
  <section class="mx-auto max-w-[1600px] px-6 py-24 md:px-10 md:py-32">
    <div class="space-y-24 md:space-y-32">
      {
        groups.map((group, i) => (
          <div class="grid gap-10 md:grid-cols-12 md:gap-8 md:items-center" data-reveal-group>
            <div
              data-reveal
              class={`overflow-hidden md:col-span-5 ${i % 2 === 1 ? "md:col-start-8" : ""}`}
              style="aspect-ratio: 4/5;"
            >
              <img
                data-parallax
                src={group.image}
                alt={group.alt}
                class="h-full w-full object-cover will-change-transform"
                loading="lazy"
              />
            </div>
            <div class={`md:col-span-6 ${i % 2 === 1 ? "md:col-start-1 md:row-start-1" : "md:col-start-7"}`}>
              <p data-reveal class="text-sm uppercase tracking-wide text-stone">
                {group.location}
              </p>
              <h2 data-reveal class="mt-2 font-display text-[clamp(1.5rem,2.6vw,2.25rem)] leading-[1.1] text-ink">
                {group.residence}
              </h2>

              <div class="mt-8 space-y-8">
                {group.quotes.map((q) => (
                  <blockquote data-reveal class="border-l border-brass/40 pl-6">
                    <p class="text-lg leading-relaxed text-ink md:text-xl">
                      &ldquo;{q.quote}&rdquo;
                    </p>
                    <footer class="mt-3 text-sm uppercase tracking-wide text-stone">
                      {q.name}
                    </footer>
                  </blockquote>
                ))}
              </div>

              <a
                data-reveal
                href={`/residences/${group.slug}`}
                class="group mt-8 inline-flex items-center gap-2 text-sm uppercase tracking-wide text-ink"
              >
                View {group.residence}
                <span class="h-px w-6 bg-ink transition-all duration-300 group-hover:w-10 group-hover:bg-brass" />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="border-t border-stone/15 bg-ink py-24 text-bone md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
      <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.1]">
        Start your own story with MERIDIAN.
      </h2>
      <a
        data-reveal
        href="/contact#schedule"
        class="mt-8 inline-block rounded-full border border-brass px-7 py-3 text-sm tracking-wide text-bone transition-colors duration-300 hover:bg-brass hover:text-ink"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</Layout>
