---
import Layout from "../layouts/Layout.astro";
import { amenities, philosophy } from "../data/experience.js";
---

<Layout
  title="The Experience"
  description="Amenities, design philosophy, and the architecture and interiors story behind every MERIDIAN residence."
>
  <section class="relative flex h-[60svh] min-h-[420px] w-full items-end overflow-hidden bg-ink" data-reveal-group>
    <!-- PLACEHOLDER: temporary stock photo -- swap for commissioned/final photography -->
    <img
      data-kenburns
      src="/images/experience/hero-experience.avif"
      alt="Rooftop pool lounge at dusk with the Miami skyline across the bay"
      class="absolute inset-0 h-full w-full object-cover will-change-transform"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-overlay"></div>
    <div class="relative z-10 mx-auto w-full max-w-[1600px] px-6 pb-16 md:px-10 md:pb-20">
      <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">The Experience</p>
      <h1
        data-reveal
        class="mt-4 max-w-3xl font-display text-[clamp(2.25rem,6vw,4.5rem)] leading-[1.05] text-bone"
      >
        Amenities considered like architecture.
      </h1>
    </div>
  </section>

  <section class="mx-auto max-w-[1600px] px-6 py-24 md:px-10 md:py-32" data-reveal-group>
    <p data-reveal class="max-w-[65ch] text-base leading-relaxed text-stone md:text-lg">
      A MERIDIAN residence isn't sold on its square footage. It's sold on
      the fifteen minutes before dinner spent on a rooftop terrace, the
      unhurried walk from dock to door, and the small design decisions --
      where the light falls, how a room breathes -- that a template
      development never quite gets right.
    </p>
  </section>

  <section class="border-t border-stone/15 bg-bone py-24 md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 md:px-10">
      <h2 data-reveal class="mb-14 font-display text-[clamp(2rem,4vw,3.25rem)] leading-[1.05] text-ink md:mb-20">
        Amenities
      </h2>
      <div class="space-y-20 md:space-y-28">
        {
          amenities.map((a, i) => (
            <div class="grid gap-8 md:grid-cols-12 md:gap-8 md:items-center">
              <div
                data-reveal
                class={`overflow-hidden md:col-span-6 ${i % 2 === 1 ? "md:col-start-7" : ""}`}
              >
                <img
                  data-parallax
                  src={a.image.src}
                  alt={a.image.alt}
                  style={`aspect-ratio: ${a.image.ratio};`}
                  class="h-full w-full object-cover will-change-transform"
                  loading="lazy"
                />
              </div>
              <div class={`md:col-span-5 ${i % 2 === 1 ? "md:col-start-1 md:row-start-1" : "md:col-start-8"}`}>
                <h3 data-reveal class="font-display text-[clamp(1.5rem,2.5vw,2rem)] leading-[1.1] text-ink">
                  {a.name}
                </h3>
                <p data-reveal class="mt-4 max-w-[45ch] text-base leading-relaxed text-stone">
                  {a.copy}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-stone/15 bg-ink py-24 text-bone md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 md:px-10">
      <h2 data-reveal class="mb-14 font-display text-[clamp(2rem,4vw,3.25rem)] leading-[1.05] md:mb-20">
        Design Philosophy
      </h2>
      <div class="grid gap-12 md:grid-cols-3 md:gap-10">
        {
          philosophy.map((p) => (
            <div data-reveal>
              <p class="text-sm uppercase tracking-[0.15em] text-brass">{p.title}</p>
              <p class="mt-4 max-w-[38ch] text-base leading-relaxed text-bone/80">
                {p.copy}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
      <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.1] text-ink">
        Experience it in person.
      </h2>
      <a
        data-reveal
        href="/contact#schedule"
        class="mt-8 inline-block rounded-full border border-ink px-7 py-3 text-sm tracking-wide text-ink transition-colors duration-300 hover:bg-ink hover:text-bone"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</Layout>
