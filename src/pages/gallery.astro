---
import Layout from "../layouts/Layout.astro";
import PlaceholderImage from "../components/shared/PlaceholderImage.astro";
import { galleryGroups } from "../data/gallery.js";
---

<Layout
  title="Gallery"
  description="A full visual tour of MERIDIAN residences -- exteriors, interiors, and the lifestyle around them."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">Gallery</p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      A closer look.
    </h1>
    <p data-reveal class="mt-6 max-w-[60ch] text-base leading-relaxed text-stone md:text-lg">
      Select any image to view it in full. A number of these photographs
      are placeholder imagery standing in for commissioned photography of
      the finished residences.
    </p>
  </section>

  {
    galleryGroups.map((group) => (
      <section class="mx-auto max-w-[1600px] px-6 pb-24 md:px-10 md:pb-32" data-reveal-group>
        <h2 data-reveal class="mb-8 font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.1] text-ink md:mb-12">
          {group.label}
        </h2>
        <div class="grid gap-6 md:grid-cols-4 md:gap-6">
          {group.items.map((item, i) => (
            <button
              type="button"
              data-reveal
              data-lightbox-trigger
              data-lightbox-src={item.type === "photo" ? item.src : ""}
              data-lightbox-alt={item.type === "photo" ? item.alt : item.label}
              data-lightbox-label={item.type === "placeholder" ? item.label : ""}
              class={`group block w-full overflow-hidden text-left ${i === 0 ? "md:col-span-2 md:row-span-2" : ""}`}
            >
              {item.type === "photo" ? (
                <img
                  data-parallax
                  src={item.src}
                  alt={item.alt}
                  style={`aspect-ratio: ${item.ratio};`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02] will-change-transform"
                  loading="lazy"
                />
              ) : (
                <PlaceholderImage label={item.label} ratio={item.ratio} />
              )}
            </button>
          ))}
        </div>
      </section>
    ))
  }

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-ink/95 p-6 md:p-16"
    role="dialog"
    aria-modal="true"
    aria-label="Image preview"
  >
    <button
      id="lightbox-close"
      type="button"
      aria-label="Close image preview"
      class="absolute right-6 top-6 flex h-11 w-11 items-center justify-center text-bone transition-colors duration-300 hover:text-brass"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M2 2L18 18M18 2L2 18" />
      </svg>
    </button>
    <div class="max-h-full max-w-full">
      <img id="lightbox-img" src="" alt="" class="hidden max-h-[85vh] max-w-full object-contain" />
      <div id="lightbox-placeholder" class="hidden max-w-2xl">
        <div class="flex aspect-[4/3] items-center justify-center border border-bone/20 bg-ink/40 px-8 text-center">
          <span id="lightbox-placeholder-label" class="text-sm uppercase tracking-[0.1em] text-bone/70"></span>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Plain JS (no TS type annotations) per project convention -- see Header.astro.
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img");
    const lightboxPlaceholder = document.getElementById("lightbox-placeholder");
    const lightboxPlaceholderLabel = document.getElementById("lightbox-placeholder-label");
    const closeBtn = document.getElementById("lightbox-close");
    const triggers = document.querySelectorAll("[data-lightbox-trigger]");
    let lastFocused = null;

    function openLightbox(trigger) {
      if (!lightbox || !lightboxImg || !lightboxPlaceholder || !lightboxPlaceholderLabel) return;
      lastFocused = document.activeElement;
      const src = trigger.getAttribute("data-lightbox-src");
      const alt = trigger.getAttribute("data-lightbox-alt") || "";
      const label = trigger.getAttribute("data-lightbox-label");

      if (src) {
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightboxImg.classList.remove("hidden");
        lightboxPlaceholder.classList.add("hidden");
      } else {
        lightboxPlaceholderLabel.textContent = `IMAGE: ${label}`;
        lightboxPlaceholder.classList.remove("hidden");
        lightboxImg.classList.add("hidden");
      }

      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
      if (closeBtn) closeBtn.focus();
      document.addEventListener("keydown", onKeydown);
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
      document.removeEventListener("keydown", onKeydown);
      if (lastFocused) lastFocused.focus();
    }

    function onKeydown(e) {
      if (e.key === "Escape") closeLightbox();
    }

    triggers.forEach((t) => t.addEventListener("click", () => openLightbox(t)));
    if (closeBtn) closeBtn.addEventListener("click", closeLightbox);
    if (lightbox) {
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });
    }
  </script>
</Layout>
