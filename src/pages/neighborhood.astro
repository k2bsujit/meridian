---
import Layout from "../layouts/Layout.astro";
import { anchors } from "../data/neighborhood.js";
---

<Layout
  title="Neighborhood"
  description="Coconut Grove, Bay Harbor Islands, Sunset Harbour, and Belle Meade -- the waterfront neighborhoods where MERIDIAN residences are located."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">Neighborhood</p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      Set along Biscayne Bay.
    </h1>
    <p data-reveal class="mt-6 max-w-[60ch] text-base leading-relaxed text-stone md:text-lg">
      Ten minutes from the Design District, walking distance to Coconut
      Grove's oldest banyan canopy, and close enough to the bay to hear
      it at night. MERIDIAN residences sit across four connected
      waterfront neighborhoods -- Coconut Grove, Bay Harbor Islands,
      Sunset Harbour, and Belle Meade -- each with its own texture, all
      within a short drive of one another.
    </p>
  </section>

  <section class="mx-auto max-w-[1600px] px-6 pb-24 md:px-10 md:pb-32" data-reveal-group>
    <div data-reveal class="overflow-hidden" style="aspect-ratio: 21/9;">
      <img
        data-parallax
        src="/images/neighborhood-street.avif"
        alt="Sunny coastal Miami streetscape at golden hour"
        class="h-full w-full object-cover will-change-transform"
        loading="lazy"
      />
    </div>
  </section>

  <section class="border-t border-stone/15 bg-bone py-24 md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 md:px-10">
      <h2 data-reveal class="mb-14 font-display text-[clamp(2rem,4vw,3.25rem)] leading-[1.05] text-ink md:mb-20">
        Nearby
      </h2>
      <div class="grid gap-x-8 gap-y-12 md:grid-cols-3">
        {
          anchors.map((a) => (
            <div data-reveal class="border-t border-stone/20 pt-6">
              <p class="text-xs uppercase tracking-[0.15em] text-brass">
                {a.category}
              </p>
              <h3 class="mt-3 font-display text-xl text-ink">{a.name}</h3>
              <p class="mt-1 text-sm uppercase tracking-wide text-stone">
                {a.distance}
              </p>
              <p class="mt-3 max-w-[38ch] text-sm leading-relaxed text-stone">
                {a.copy}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-stone/15 py-24 md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 md:px-10">
      <h2 data-reveal class="mb-10 font-display text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.1] text-ink md:mb-14">
        Find Us
      </h2>
      <div data-reveal class="overflow-hidden" style="aspect-ratio: 21/9;">
        <iframe
          src="https://www.google.com/maps?q=Coconut+Grove,+Miami,+FL&output=embed"
          title="Map of MERIDIAN neighborhoods in Miami, FL"
          class="h-full w-full"
          style="border:0;"
          loading="lazy"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="border-t border-stone/15 bg-ink py-24 text-bone md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
      <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.1]">
        Walk the neighborhood with us.
      </h2>
      <a
        data-reveal
        href="/contact#schedule"
        class="mt-8 inline-block rounded-full border border-brass px-7 py-3 text-sm tracking-wide text-bone transition-colors duration-300 hover:bg-brass hover:text-ink"
      >
        Schedule Appointment
      </a>
    </div>
  </section>
</Layout>
