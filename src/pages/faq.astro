---
import Layout from "../layouts/Layout.astro";
import { faqs } from "../data/faqs.js";
---

<Layout
  title="FAQs"
  description="Answers to common questions about private tours, pricing, financing, HOA details, and availability at MERIDIAN."
>
  <section class="mx-auto max-w-[1600px] px-6 pb-16 pt-40 md:px-10 md:pb-24 md:pt-52" data-reveal-group>
    <p data-reveal class="text-sm uppercase tracking-[0.2em] text-brass">FAQs</p>
    <h1
      data-reveal
      class="mt-4 max-w-3xl font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] text-ink"
    >
      Questions, answered plainly.
    </h1>
    <p data-reveal class="mt-6 max-w-[60ch] text-base leading-relaxed text-stone md:text-lg">
      The questions we hear most often, from private tours through
      closing. If yours isn't covered here, reach out directly and we'll
      answer it personally.
    </p>
  </section>

  <section class="border-t border-stone/15 bg-bone py-20 md:py-28" data-reveal-group>
    <div class="mx-auto max-w-[900px] px-6 md:px-10">
      <div class="divide-y divide-stone/15 border-t border-stone/15">
        {
          faqs.map((item, i) => (
            <div data-reveal>
              <h2>
                <button
                  type="button"
                  data-faq-toggle={i}
                  aria-expanded="false"
                  aria-controls={`faq-panel-${i}`}
                  class="flex w-full items-center justify-between gap-6 py-6 text-left"
                >
                  <span class="font-display text-lg text-ink md:text-xl">{item.q}</span>
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                    class="faq-chevron shrink-0 text-ink transition-transform duration-300"
                  >
                    <path d="M2 5L7 10L12 5" />
                  </svg>
                </button>
              </h2>
              <div id={`faq-panel-${i}`} data-faq-panel={i} class="hidden pb-6">
                <p class="max-w-[65ch] text-base leading-relaxed text-stone">{item.a}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-stone/15 bg-ink py-24 text-bone md:py-32" data-reveal-group>
    <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
      <h2 data-reveal class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.1]">
        Still have a question?
      </h2>
      <p data-reveal class="mx-auto mt-4 max-w-[50ch] text-base leading-relaxed text-bone/80">
        Reach out directly and we'll get back to you within one business day.
      </p>
      <a
        data-reveal
        href="/contact#schedule"
        class="mt-8 inline-block rounded-full border border-brass px-7 py-3 text-sm tracking-wide text-bone transition-colors duration-300 hover:bg-brass hover:text-ink"
      >
        Contact Us
      </a>
    </div>
  </section>

  <script>
    // Plain JS (no TS annotations) per project convention -- see Header.astro.
    const faqToggles = document.querySelectorAll("[data-faq-toggle]");

    function closeFaq(t) {
      const key = t.getAttribute("data-faq-toggle");
      const p = document.querySelector(`[data-faq-panel="${key}"]`);
      if (!p) return;
      p.classList.add("hidden");
      t.setAttribute("aria-expanded", "false");
      t.classList.remove("is-open");
    }

    function openFaq(t) {
      const key = t.getAttribute("data-faq-toggle");
      const p = document.querySelector(`[data-faq-panel="${key}"]`);
      if (!p) return;
      p.classList.remove("hidden");
      t.setAttribute("aria-expanded", "true");
      t.classList.add("is-open");
    }

    faqToggles.forEach((t) => {
      t.addEventListener("click", () => {
        const isOpen = t.getAttribute("aria-expanded") === "true";
        isOpen ? closeFaq(t) : openFaq(t);
      });
    });
  </script>
</Layout>
